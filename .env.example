# RPC URLs
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# Private key (with or without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Contract addresses (set after deploying verifier)
VERIFIER_ADDRESS=0x...
TOKEN_ADDRESS=0x...

# Guest program image ID (get from cargo build output)
IMAGE_ID=0x...

# Merkle root (get from build-tree command)
MERKLE_ROOT=0x...

# Airdrop configuration
AMOUNT_PER_CLAIM=1000000000000000000

# Claim deadline (unix timestamp, 0 = no deadline)
CLAIM_DEADLINE=0

# Etherscan API key for verification
OPTIMISM_ETHERSCAN_API_KEY=your_api_key_here
